# =============================================================================
# OPEN MILITARY HARDWARE DATABASE - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
POSTGRES_USER=omhdb
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql://omhdb:your-secure-password-here@localhost:5432/military_hardware

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
SECRET_KEY=your-secure-secret-key-change-in-production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# API admin login (FastAPI /api/v1/auth/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# In Docker Compose, repo is mounted at /import for seed + JSON schema (set automatically for api service)
# OMHDB_REPO_ROOT=/import

# -----------------------------------------------------------------------------
# RAG / AI
# -----------------------------------------------------------------------------
CHROMA_URL=http://localhost:8333
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=llama3.2:8b
LLM_TEMPERATURE=0.7

# Optional: External LLM APIs (uncomment to use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_RAG_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# OPTIONAL SERVICES
# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# Sentry (error tracking)
# SENTRY_DSN=https://...

# -----------------------------------------------------------------------------
# DEVELOPMENT
# -----------------------------------------------------------------------------
# Set to 'development' or 'production'
ENVIRONMENT=development
